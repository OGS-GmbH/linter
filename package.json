{
  "name": "@ogs-gmbh/linter",
  "description": "Linter rules to enforce consistent, high-quality code across projects.",
  "version": "2.0.0",
  "author": "OGS GmbH",
  "exports": {
    ".": {
      "types": "./public-api.d.ts",
      "default": "./public-api.mjs"
    }
  },
  "homepage": "https://ogs-gmbh.github.io/linter/",
  "bugs": "https://github.com/OGS-GmbH/linter/issues",
  "license": "MIT",
  "keywords": [
    "eslint",
    "static-code-analysis",
    "linter",
    "code-quality",
    "typescript-eslint"
  ],
  "repository": "github:OGS-GmbH/linter",
  "publishConfig": {
    "directory": "dist/main"
  },
  "peerDependencies": {
    "@commitlint/cli": "^20",
    "@commitlint/config-conventional": "^20",
    "@commitlint/prompt-cli": "^20",
    "@eslint/js": "^9",
    "@eslint/json": "^0",
    "@eslint/markdown": "^7",
    "@stylistic/eslint-plugin": "^5",
    "angular-eslint": "^21",
    "eslint": "^9",
    "eslint-plugin-jsdoc": "^62",
    "eslint-plugin-security": "^3",
    "eslint-plugin-unicorn": "^56",
    "globals": "^17",
    "husky": "^9",
    "lint-staged": "^16",
    "npm-package-json-lint": "^9",
    "stylelint": "^17",
    "stylelint-scss": "^7",
    "typescript-eslint": "^8"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "@eslint/js": {
      "optional": true
    },
    "typescript-eslint": {
      "optional": true
    },
    "@stylistic/eslint-plugin": {
      "optional": true
    },
    "eslint-plugin-unicorn": {
      "optional": true
    },
    "eslint-plugin-security": {
      "optional": true
    },
    "angular-eslint": {
      "optional": true
    },
    "stylelint": {
      "optional": true
    },
    "stylelint-scss": {
      "optional": true
    },
    "@eslint/json": {
      "optional": true
    },
    "@eslint/markdown": {
      "optional": true
    },
    "husky": {
      "optional": true
    },
    "@commitlint/cli": {
      "optional": true
    },
    "@commitlint/config-conventional": {
      "optional": true
    },
    "@commitlint/prompt-cli": {
      "optional": true
    },
    "lint-staged": {
      "optional": true
    },
    "globals": {
      "optional": true
    },
    "npm-package-json-lint": {
      "optional": true
    },
    "eslint-plugin-jsdoc": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ogs-gmbh/vitepress-plugin-sidebar": "^1.0.2",
    "@ogs-gmbh/vitepress-theme": "^1.0.1",
    "esbuild": "^0.27.2",
    "esbuild-plugin-d.ts": "^1.3.1",
    "esbuild-plugin-file-copy": "2.0.0-next.0",
    "esbuild-plugin-file-path-extensions": "^2.1.4",
    "esbuild-plugin-package-json": "^2.0.0",
    "fast-glob": "^3.3.3",
    "sass-embedded": "^1.97.3",
    "typedoc": "^0.28.16",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.1"
  },
  "scripts": {
    "ci:build:main:production": "node .esbuild/build.mjs",
    "ci:docs:extract:typedoc": "typedoc",
    "ci:docs:main:vitepress": "bash ./.vitepress/scripts/pre-vitepress.sh && vitepress build .vitepress",
    "ci:pr:commitlint:main:commitlint": "commitlint",
    "ci:pr:lint:main:eslint": "eslint .",
    "commit": "commit",
    "prepare": "husky",
    "vitepress": "bash ./.vitepress/scripts/pre-vitepress.sh && vitepress dev .vitepress",
    "vitepress:preview": "vitepress preview .vitepress"
  }
}
